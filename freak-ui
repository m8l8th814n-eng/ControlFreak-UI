class ParamRow(QWidget):
    changed = pyqtSignal(str, float)

    def __init__(self, name: str):
        super().__init__()
        self.name = name
        self.color = PARAM_COLORS[name]
        self._block = False

        lay = QHBoxLayout(self)
        lay.setContentsMargins(8, 2, 8, 2)
        lay.setSpacing(8)

        self.label = QLabel(name.upper())
        self.label.setMinimumWidth(80)
        f = self.label.font()
        f.setBold(True)
        f.setPointSize(10)
        self.label.setFont(f)
        self.label.setStyleSheet(f"color: {self.color};")
        lay.addWidget(self.label)

        self.minus = QPushButton("−")
        self.minus.setFixedSize(38, 38)
        self.minus.setObjectName("paramBtn")
        self.minus.clicked.connect(lambda: self._step(-1.0))
        lay.addWidget(self.minus)

        self.slider = QSlider(Qt.Orientation.Horizontal)
        self.slider.setObjectName(f"slider_{name}")
        self.slider.setRange(0, 1000)
        self.slider.setValue(800)
        self.slider.setSingleStep(10)
        self.slider.setPageStep(50)
        self.slider.setMinimumHeight(40)
        self.slider.valueChanged.connect(self._on_slider)
        lay.addWidget(self.slider, 1)

        self.plus = QPushButton("+")
        self.plus.setFixedSize(38, 38)
        self.plus.setObjectName("paramBtn")
        self.plus.clicked.connect(lambda: self._step(1.0))
        lay.addWidget(self.plus)

        self.value_label = QLabel("80%")
        self.value_label.setMinimumWidth(48)
        self.value_label.setAlignment(Qt.AlignmentFlag.AlignRight | Qt.AlignmentFlag.AlignVCenter)
        self.value_label.setStyleSheet(f"color: {LGRAY}; font-weight: bold;")
        lay.addWidget(self.value_label)

        self._apply_slider_style()

    def _apply_slider_style(self):
        self.slider.setStyleSheet(
            f"""
            QSlider {{ height: 40px; }}
            QSlider::groove:horizontal {{
                height: 14px; background: {BG3};
                border: 1px solid {BORDER}; border-radius: 7px;
            }}
            QSlider::sub-page:horizontal {{
                background: {self.color}; border-radius: 7px;
            }}
            QSlider::handle:horizontal {{
                width: 30px; height: 30px; margin: -10px 0;
                background: {self.color};
                border: 2px solid white; border-radius: 16px;
            }}
            QSlider::handle:horizontal:hover {{ border: 2px solid {PINK}; }}
            """
        )

    def _on_slider(self, val: int):
        pct = val / 10.0
        self.value_label.setText(f"{pct:.0f}%")
        if not self._block:
            self.changed.emit(self.name, pct)

    def _step(self, delta: float):
        new = max(0.0, min(100.0, self.value() + delta))
        self.set_value(new)
        self.changed.emit(self.name, new)

    def value(self) -> float:
        return self.slider.value() / 10.0

    def set_value(self, pct: float):
        self._block = True
        self.slider.setValue(int(round(pct * 10)))
        self.value_label.setText(f"{pct:.0f}%")
        self._block = False


