# ---------------------------------------------------------------------------
# IPC client
# ---------------------------------------------------------------------------

class FreakClient:
    def __init__(self, path: str = SOCKET_PATH):
        self.path = path

    def _send(self, cmd: str, timeout: float = 0.5) -> Optional[str]:
        try:
            s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            s.settimeout(timeout)
            s.connect(self.path)
            s.sendall((cmd + "\n").encode())
            data = b""
            while b"\n" not in data:
                chunk = s.recv(4096)
                if not chunk:
                    break
                data += chunk
            s.close()
            return data.decode().strip()
        except (OSError, socket.timeout):
            return None

    def alive(self) -> bool:
        return self._send("GET") is not None

    def get(self) -> Optional[dict]:
        r = self._send("GET")
        if not r:
            return None
        try:
            return json.loads(r)
        except json.JSONDecodeError:
            return None

    def set(self, field: str, value: float) -> bool:
        r = self._send(f"SET {field} {value:.1f}")
        return r is not None and r.startswith("OK")

    def reset(self) -> bool:
        r = self._send("RESET")
        return r is not None and r.startswith("OK")

    def load(self, name: str) -> bool:
        r = self._send(f"LOAD {name}")
        return r is not None and r.startswith("OK")

    def save(self, name: str) -> bool:
        r = self._send(f"SAVE {name}")
        return r is not None and r.startswith("OK")

    def presets(self) -> list[str]:
        r = self._send("PRESETS")
        if not r:
            return []
        try:
            return json.loads(r)
        except json.JSONDecodeError:
            return []


# ---------------------------------------------------------------------------
# Daemon manager
# ---------------------------------------------------------------------------

def detect_init() -> str:
    if shutil.which("systemctl") and Path("/run/systemd/system").exists():
        return "systemd"
    if shutil.which("rc-service") or shutil.which("openrc"):
        return "openrc"
    return "none"


def freak_binary() -> str:
    for p in (
        Path.home() / ".local/bin/freak",
        Path("/usr/local/bin/freak"),
        Path("/usr/bin/freak"),
    ):
        if p.is_file():
            return str(p)
    return "freak"


def ensure_systemd_unit() -> None:
    if USER_UNIT_PATH.exists():
        return
    USER_UNIT_PATH.parent.mkdir(parents=True, exist_ok=True)
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
    wayland = os.environ.get("WAYLAND_DISPLAY", "wayland-0")
    USER_UNIT_PATH.write_text(
        "[Unit]\n"
        "Description=freak gamma daemon\n"
        "After=graphical-session.target\n"
        "PartOf=graphical-session.target\n\n"
        "[Service]\n"
        "Type=simple\n"
        f"ExecStart={freak_binary()} --daemon\n"
        "Restart=on-failure\n"
        "RestartSec=2\n"
        f"Environment=WAYLAND_DISPLAY={wayland}\n"
        f"Environment=XDG_RUNTIME_DIR={runtime_dir}\n\n"
        "[Install]\n"
        "WantedBy=graphical-session.target\n"
    )
    subprocess.run(["systemctl", "--user", "daemon-reload"], check=False)


class DaemonManager:
    def __init__(self):
        self.init = detect_init()

    def is_running(self) -> bool:
        if self.init == "systemd":
            r = subprocess.run(
                ["systemctl", "--user", "is-active", SERVICE_NAME],
                capture_output=True, text=True,
            )
            return r.stdout.strip() == "active"
        if self.init == "openrc" and OPENRC_INIT_PATH.exists():
            r = subprocess.run(
                ["rc-service", SERVICE_NAME, "status"],
                capture_output=True, text=True,
            )
            return r.returncode == 0
        try:
            r = subprocess.run(
                ["pgrep", "-f", f"{freak_binary()} --daemon"],
                capture_output=True,
            )
            return r.returncode == 0
        except FileNotFoundError:
            return False

    def start(self) -> tuple[bool, str]:
        if self.init == "systemd":
            ensure_systemd_unit()
            r = subprocess.run(
                ["systemctl", "--user", "enable", "--now", SERVICE_NAME],
                capture_output=True, text=True,
            )
            ok = r.returncode == 0
            return ok, (r.stderr or r.stdout).strip() or ("started" if ok else "failed")
        if self.init == "openrc":
            if not OPENRC_INIT_PATH.exists():
                return False, "OpenRC init script /etc/init.d/freak saknas (kräver root)"
            r = subprocess.run(
                ["rc-service", SERVICE_NAME, "start"],
                capture_output=True, text=True,
            )
            return r.returncode == 0, (r.stderr or r.stdout).strip()
        try:
            subprocess.Popen(
                [freak_binary(), "--daemon"],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
            return True, "started directly (no init system detected)"
        except OSError as e:
            return False, str(e)

    def stop(self) -> tuple[bool, str]:
        if self.init == "systemd":
            r = subprocess.run(
                ["systemctl", "--user", "disable", "--now", SERVICE_NAME],
                capture_output=True, text=True,
            )
            return r.returncode == 0, (r.stderr or r.stdout).strip()
        if self.init == "openrc" and OPENRC_INIT_PATH.exists():
            r = subprocess.run(
                ["rc-service", SERVICE_NAME, "stop"],
                capture_output=True, text=True,
            )
            return r.returncode == 0, (r.stderr or r.stdout).strip()
        r = subprocess.run(["pkill", "-f", f"{freak_binary()} --daemon"])
        return r.returncode == 0, "stopped"


# ---------------------------------------------------------------------------
# Resolution (wlr-randr)
# ---------------------------------------------------------------------------

class ResolutionManager:
    def __init__(self):
        self.have = shutil.which("wlr-randr") is not None

    def query(self) -> dict[str, dict]:
        if not self.have:
            return {}
        try:
            r = subprocess.run(
                ["wlr-randr"], capture_output=True, text=True, timeout=2
            )
        except (OSError, subprocess.TimeoutExpired):
            return {}
        outputs: dict[str, dict] = {}
        current_output = None
        for line in r.stdout.splitlines():
            m = re.match(r'^(\S+)\s+"', line)
            if m:
                current_output = m.group(1)
                outputs[current_output] = {"modes": [], "current": None}
                continue
            if current_output is None:
                continue
            m = re.match(
                r"^\s+(\d+x\d+)\s+px,\s+([\d.]+)\s+Hz(.*)$", line
            )
            if m:
                mode = f"{m.group(1)}@{float(m.group(2)):.3f}Hz"
                outputs[current_output]["modes"].append(mode)
                if "current" in m.group(3):
                    outputs[current_output]["current"] = mode
        return outputs

    def set_mode(self, output: str, mode: str) -> tuple[bool, str]:
        r = subprocess.run(
            ["wlr-randr", "--output", output, "--mode", mode],
            capture_output=True, text=True,
        )
        return r.returncode == 0, (r.stderr or r.stdout).strip()


