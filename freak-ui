class ControlFreakWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("controlFREAK for handhelds")
        self.setFixedSize(800, 400)

        self.client = FreakClient()
        self.daemon = DaemonManager()
        self.resman = ResolutionManager()

        self._build_ui()
        self._apply_theme()
        self._refresh_presets()
        self._refresh_resolutions()
        self._refresh_status()
        self._pull_params(force=True)

        self.poll = QTimer(self)
        self.poll.setInterval(800)
        self.poll.timeout.connect(self._poll)
        self.poll.start()

    # ---------- UI build ----------

    def _build_ui(self):
        central = QWidget()
        self.setCentralWidget(central)
        root = QVBoxLayout(central)
        root.setContentsMargins(10, 8, 10, 8)
        root.setSpacing(4)

        # title row
        top = QHBoxLayout()
        top.setSpacing(8)
        self.title = TitleLabel()
        top.addWidget(self.title)
        top.addStretch(1)

        self.status_dot = QLabel("●")
        self.status_dot.setStyleSheet("color: #555; font-size: 18px;")
        top.addWidget(self.status_dot)
        self.status_label = QLabel("checking…")
        self.status_label.setStyleSheet(f"color: {LGRAY};")
        top.addWidget(self.status_label)

        self.btn_start = QPushButton("Start daemon")
        self.btn_start.setObjectName("primaryBtn")
        self.btn_start.clicked.connect(self._on_start)
        top.addWidget(self.btn_start)

        self.btn_stop = QPushButton("Stop")
        self.btn_stop.clicked.connect(self._on_stop)
        top.addWidget(self.btn_stop)

        root.addLayout(top)

        sep = QFrame()
        sep.setFrameShape(QFrame.Shape.HLine)
        sep.setStyleSheet(f"color: {BORDER};")
        root.addWidget(sep)

        # sliders
        self.rows: dict[str, ParamRow] = {}
        for name in PARAM_ORDER:
            row = ParamRow(name)
            row.changed.connect(self._on_param_change)
            self.rows[name] = row
            root.addWidget(row)

        sep2 = QFrame()
        sep2.setFrameShape(QFrame.Shape.HLine)
        sep2.setStyleSheet(f"color: {BORDER};")
        root.addWidget(sep2)

        # presets row
        prow = QHBoxLayout()
        prow.setSpacing(6)
        lab = QLabel("PRESET")
        lab.setStyleSheet(f"color: {LBLUE}; font-weight: bold;")
        prow.addWidget(lab)
        self.preset_combo = QComboBox()
        self.preset_combo.setMinimumHeight(36)
        self.preset_combo.setMinimumWidth(160)
        prow.addWidget(self.preset_combo, 1)
        self.btn_load = QPushButton("Load")
        self.btn_load.clicked.connect(self._on_load_preset)
        prow.addWidget(self.btn_load)
        self.btn_save = QPushButton("Save as…")
        self.btn_save.clicked.connect(self._on_save_preset)
        prow.addWidget(self.btn_save)
        self.btn_reset = QPushButton("Reset")
        self.btn_reset.setObjectName("warnBtn")
        self.btn_reset.clicked.connect(self._on_reset)
        prow.addWidget(self.btn_reset)
        root.addLayout(prow)

        # resolution row
        rrow = QHBoxLayout()
        rrow.setSpacing(6)
        lab2 = QLabel("DISPLAY")
        lab2.setStyleSheet(f"color: {PINK}; font-weight: bold;")
        rrow.addWidget(lab2)
        self.output_combo = QComboBox()
        self.output_combo.setMinimumHeight(36)
        self.output_combo.currentIndexChanged.connect(self._on_output_change)
        rrow.addWidget(self.output_combo)
        self.mode_combo = QComboBox()
        self.mode_combo.setMinimumHeight(36)
        rrow.addWidget(self.mode_combo, 1)
        self.btn_apply_mode = QPushButton("Apply")
        self.btn_apply_mode.setObjectName("primaryBtn")
        self.btn_apply_mode.clicked.connect(self._on_apply_mode)
        rrow.addWidget(self.btn_apply_mode)
        self.btn_refresh_modes = QPushButton("↻")
        self.btn_refresh_modes.setFixedWidth(40)
        self.btn_refresh_modes.clicked.connect(self._refresh_resolutions)
        rrow.addWidget(self.btn_refresh_modes)
        root.addLayout(rrow)

    def _apply_theme(self):
