            """
        )

    # ---------- actions ----------

    def _on_param_change(self, name: str, pct: float):
        if not self.client.alive():
            return
        self.client.set(name, pct)

    def _on_start(self):
        ok, msg = self.daemon.start()
        if not ok:
            QMessageBox.warning(self, "Start failed", msg or "unknown error")
        QTimer.singleShot(400, self._refresh_status)
        QTimer.singleShot(800, lambda: self._pull_params(force=True))

    def _on_stop(self):
        ok, msg = self.daemon.stop()
        if not ok:
            QMessageBox.warning(self, "Stop failed", msg or "unknown error")
        QTimer.singleShot(400, self._refresh_status)

    def _on_reset(self):
        if self.client.alive():
            self.client.reset()
            self._pull_params(force=True)
        else:
            for r in self.rows.values():
                r.set_value(80.0)

    def _on_load_preset(self):
        name = self.preset_combo.currentText()
        if not name:
            return
        if not self.client.alive():
            QMessageBox.information(self, "Daemon offline", "Starta freak-daemonen först.")
            return
        if self.client.load(name):
            self._pull_params(force=True)
        else:
            QMessageBox.warning(self, "Load failed", f"kunde inte ladda preset '{name}'")

    def _on_save_preset(self):
        name, ok = QInputDialog.getText(self, "Save preset", "Namn på preset:")
        if not ok or not name.strip():
            return
        name = name.strip()
        if not self.client.alive():
            QMessageBox.information(self, "Daemon offline", "Starta freak-daemonen först.")
            return
        if self.client.save(name):
            self._refresh_presets(select=name)
        else:
            QMessageBox.warning(self, "Save failed", f"kunde inte spara preset '{name}'")

    def _on_output_change(self):
        if not hasattr(self, "_outputs") or not self._outputs:
            return
        out = self.output_combo.currentText()
        info = self._outputs.get(out)
        if not info:
            return
        self.mode_combo.blockSignals(True)
        self.mode_combo.clear()
        for m in info["modes"]:
            self.mode_combo.addItem(m)
        if info["current"]:
            i = self.mode_combo.findText(info["current"])
            if i >= 0:
                self.mode_combo.setCurrentIndex(i)
        self.mode_combo.blockSignals(False)

    def _on_apply_mode(self):
        out = self.output_combo.currentText()
        mode = self.mode_combo.currentText()
        if not out or not mode:
            return
        wlr_mode = mode.replace("Hz", "")
        ok, msg = self.resman.set_mode(out, wlr_mode)
        if not ok:
            QMessageBox.warning(self, "wlr-randr", msg or "failed")
        QTimer.singleShot(300, self._refresh_resolutions)

    # ---------- refresh ----------

    def _refresh_presets(self, select: Optional[str] = None):
        current = select or self.preset_combo.currentText()
        self.preset_combo.blockSignals(True)
        self.preset_combo.clear()
        names = self.client.presets() if self.client.alive() else []
        if not names:
            # fallback: read from disk
            d = Path.home() / ".config/controlorfreak/presets"
            if d.is_dir():
                names = sorted(p.stem for p in d.glob("*.freak"))
        for n in sorted(names):
            self.preset_combo.addItem(n)
        if current:
            i = self.preset_combo.findText(current)
            if i >= 0:
                self.preset_combo.setCurrentIndex(i)
        self.preset_combo.blockSignals(False)

    def _refresh_resolutions(self):
        if not self.resman.have:
            self.output_combo.clear()
            self.output_combo.addItem("(wlr-randr saknas)")
            self.output_combo.setEnabled(False)
            self.mode_combo.setEnabled(False)
            self.btn_apply_mode.setEnabled(False)
            return
        self._outputs = self.resman.query()
        prev_out = self.output_combo.currentText()
        self.output_combo.blockSignals(True)
        self.output_combo.clear()
        for name in self._outputs:
            self.output_combo.addItem(name)
        if prev_out:
            i = self.output_combo.findText(prev_out)
            if i >= 0:
                self.output_combo.setCurrentIndex(i)
        self.output_combo.blockSignals(False)
        self._on_output_change()

    def _refresh_status(self):
        alive = self.client.alive()
        running = self.daemon.is_running()
        if alive:
            self.status_dot.setStyleSheet(f"color: {PARAM_COLORS['green']}; font-size: 18px;")
            self.status_label.setText(f"daemon · {self.daemon.init}")
        elif running:
            self.status_dot.setStyleSheet(f"color: {PARAM_COLORS['contrast']}; font-size: 18px;")
            self.status_label.setText(f"running, no IPC · {self.daemon.init}")
        else:
            self.status_dot.setStyleSheet(f"color: #555; font-size: 18px;")
            self.status_label.setText(f"stopped · {self.daemon.init}")

    def _pull_params(self, force: bool = False):
        data = self.client.get()
        if not data:
            return
        for name, row in self.rows.items():
            if name in data:
                v = float(data[name])
                if force or abs(row.value() - v) > 0.05:
                    row.set_value(v)

    def _poll(self):
        self._refresh_status()
        self._pull_params()


# ---------------------------------------------------------------------------

def main():
    app = QApplication(sys.argv)
    app.setApplicationName("controlFREAK")
    w = ControlFreakWindow()
    w.show()
    sys.exit(app.exec())


